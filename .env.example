# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose 내부 서비스명을 호스트로 사용한다.
DB_HOST=db
DB_PORT=3306
DB_NAME=ssac_db
DB_USERNAME=ssac_user
DB_PASSWORD=
DB_ROOT_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# JWT_SECRET: 32자 이상의 임의 문자열 (보안상 반드시 변경할 것)
JWT_SECRET=
JWT_ACCESS_EXPIRATION=1800000
JWT_REFRESH_EXPIRATION=604800000

# ── OAuth - Kakao ─────────────────────────────────────────────────────────────
# https://developers.kakao.com 에서 발급
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/login/oauth2/code/kakao

# ── OAuth - Naver ─────────────────────────────────────────────────────────────
# https://developers.naver.com 에서 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:8080/api/v1/auth/naver/callback

# ── CORS / OAuth2 리디렉션 ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
OAUTH2_DEFAULT_REDIRECT_URI=http://localhost:3000
