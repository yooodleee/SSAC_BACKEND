# .env.example — 실제 값은 .env 파일에 복사 후 입력하세요.
# .env 파일은 .gitignore에 의해 추적되지 않습니다.

# Slack 인바운드 웹훅 URL
# 발급: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/YOUR_TOKEN

# 네이버 OAuth 애플리케이션 자격증명
# 발급: https://developers.naver.com/apps → 애플리케이션 등록 → 네아로(네이버 아이디로 로그인)
NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID
NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET
