# ── Spring ────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── DB (Railway MySQL Plugin 참조) ────────────────────────────────────────────
DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# ── Redis (Railway Redis Plugin 참조) ─────────────────────────────────────────
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# JWT_SECRET: openssl rand -base64 32 으로 생성한 32자 이상 랜덤 문자열
# 소스 코드에 하드코딩 금지 — Railway Variables에만 등록
JWT_SECRET=
JWT_ACCESS_EXPIRATION=1800000
JWT_REFRESH_EXPIRATION=604800000

# ── Kakao OAuth ───────────────────────────────────────────────────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=

# ── Naver OAuth ───────────────────────────────────────────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=

# ── CORS / Cookie (FE 배포 도메인 확정 후 등록) ───────────────────────────────
# SameSite=None 은 반드시 Secure=true 와 함께 설정해야 브라우저가 허용한다.
CORS_ALLOWED_ORIGINS=
OAUTH2_DEFAULT_REDIRECT_URI=
COOKIE_SECURE=true
COOKIE_SAME_SITE=None
