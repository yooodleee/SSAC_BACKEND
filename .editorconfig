# EditorConfig — IntelliJ, VS Code, Eclipse 등 대부분의 IDE가 자동 적용한다.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.java]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json,js,ts}]
indent_size = 2

[*.properties]
charset = utf-8

[*.{bat,cmd}]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false
