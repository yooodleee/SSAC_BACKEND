# ── 기본값: 텍스트 파일은 LF, 바이너리는 그대로 ─────────────────────────────
* text=auto eol=lf

# ── 플랫폼 고유 줄바꿈 ──────────────────────────────────────────────────────
/gradlew        text eol=lf
*.bat           text eol=crlf
*.cmd           text eol=crlf

# ── 소스 파일 (UTF-8 명시) ───────────────────────────────────────────────────
*.java          text eol=lf
*.kt            text eol=lf
*.properties    text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.xml           text eol=lf
*.json          text eol=lf
*.sql           text eol=lf
*.md            text eol=lf
*.gradle        text eol=lf

# ── 바이너리 (diff/merge 제외) ───────────────────────────────────────────────
*.jar           binary
*.class         binary
*.png           binary
*.jpg           binary
*.gif           binary
*.ico           binary
*.pdf           binary
