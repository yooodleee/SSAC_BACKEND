<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.0//EN"
    "https://checkstyle.org/dtds/suppressions_1_0.dtd">

<!--
  Checkstyle 예외 설정
  규칙 변경 시 docs/conventions.md 와 동기화하라.
-->
<suppressions>
    <!-- 테스트 메서드명: 한글 서술형 네이밍 허용 (가독성 우선, camelCase 적용 제외) -->
    <suppress checks="MethodName" files=".*Test\.java"/>

    <!-- Flyway Java Migration: V{버전}__{설명} 형식의 이름은 언더스코어를 포함하므로
         TypeName(PascalCase) 규칙 적용 제외 -->
    <suppress checks="TypeName" files=".*db[/\\]migration[/\\]V\d.*\.java"/>
</suppressions>
