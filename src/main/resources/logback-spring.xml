<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        로그 레벨 정책
        ─────────────────────────────────────────────────────────────────────────
        개발(local/dev) : DEBUG  — 상세 디버그 정보 출력
        스테이징/운영    : WARN   — 경고 이상만 출력 (INFO는 ssac 패키지 한정)
        테스트(test)    : WARN   — 테스트 출력 최소화
        ─────────────────────────────────────────────────────────────────────────

        보안 주의사항
        ─────────────────────────────────────────────────────────────────────────
        MDC에는 traceId, userId(사용자 식별자), requestId만 포함한다.
        이메일, 전화번호, Access/Refresh Token 전체 값은 절대 로깅하지 않는다.
        ─────────────────────────────────────────────────────────────────────────
    -->

    <!-- ── 기동 초기 단계 Fallback Appender ─────────────────────────────────────── -->
    <!--                                                                              -->
    <!-- 문제: 모든 Appender가 <springProfile> 블록 안에 정의되어 있으면,              -->
    <!--        Spring이 프로파일을 주입하기 전(early JVM startup) 단계에서             -->
    <!--        "No appenders present in context [default]" 경고가 출력되고            -->
    <!--        기동 초기 오류 로그가 완전히 유실된다.                                   -->
    <!--                                                                              -->
    <!-- 해결: <springProfile> 외부에 STARTUP_CONSOLE을 정의하고 root에 연결한다.       -->
    <!--        Spring이 Logback을 재초기화하면 각 <springProfile>의 root 설정이       -->
    <!--        이 기본 root에 병합(appender 추가)되어 프로파일별 Appender가 활성화된다. -->
    <appender name="STARTUP_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 기동 초기 단계 root: Spring 재초기화 후 각 springProfile의 root로 보완됨 -->
    <root level="INFO">
        <appender-ref ref="STARTUP_CONSOLE"/>
    </root>

    <!-- ── JSON 구조화 로깅 (docker, prod 프로파일) ──────────────────────────────── -->
    <!-- ELK Stack(Logstash) 및 AWS CloudWatch Logs 수집 가능한 JSON 형식 출력       -->
    <springProfile name="docker,prod">

        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>method</includeMdcKeyName>
                <includeMdcKeyName>path</includeMdcKeyName>
                <includeMdcKeyName>duration</includeMdcKeyName>
            </encoder>
        </appender>

        <!-- ssac 애플리케이션 코드: INFO 이상 출력 -->
        <logger name="com.ssac" level="INFO" additivity="false">
            <appender-ref ref="JSON_CONSOLE"/>
        </logger>

        <!-- 루트 로거: WARN 이상만 출력 (프레임워크 노이즈 최소화) -->
        <root level="WARN">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>

    </springProfile>

    <!-- ── Plain Text 로깅 (local, dev 프로파일) ─────────────────────────────────── -->
    <!-- 개발자 가독성을 위해 컬러 없는 일반 텍스트 형식 사용                           -->
    <springProfile name="local,dev">

        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [traceId=%X{traceId}] [requestId=%X{requestId}] [userId=%X{userId}] [%X{method} %X{path}] %logger{36} - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <!--
            에이전트 로그 진단용 파일 Appender
            ─────────────────────────────────────────────────────────────────────────
            logs/app.log    : 최신 로그 (에이전트가 Read 도구로 직접 읽음)
            logs/app.YYYY-MM-DD.log : 일별 롤링 (7일 보존)
            WARN 이상만 파일에 기록 — DEBUG/INFO 노이즈 제거
            ─────────────────────────────────────────────────────────────────────────
        -->
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/app.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>logs/app.%d{yyyy-MM-dd}.log</fileNamePattern>
                <maxHistory>7</maxHistory>
            </rollingPolicy>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>WARN</level>
            </filter>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [traceId=%X{traceId}] [userId=%X{userId}] [%X{method} %X{path}] %logger{36} - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <!-- ssac 애플리케이션 코드: DEBUG 출력 -->
        <logger name="com.ssac" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>

        <!-- SQL 로깅: Hibernate SQL 확인용 (운영 환경에서는 제거) -->
        <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>

    </springProfile>

    <!-- ── Plain Text 로깅 (test 프로파일) ──────────────────────────────────────── -->
    <!-- 테스트 출력 최소화: WARN 이상만 출력                                          -->
    <springProfile name="test">

        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>

    </springProfile>

</configuration>
